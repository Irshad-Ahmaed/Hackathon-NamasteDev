# --- OpenAI ---------------------------------------------------
OPENAI_API_KEY=                          # Required. Get from platform.openai.com
OPENAI_CHAT_MODEL=                       # e.g. gpt-4o-mini. Read from env everywhere.
OPENAI_REASONING_MODEL=                  # Stronger model for hard math. e.g. o4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small  # Start here. Test -large later.
OPENAI_MODERATION_MODEL=omni-moderation-latest # Free API.

# --- Qdrant ---------------------------------------------------
QDRANT_URL=                              # e.g. https://xyz.us-east.aws.cloud.qdrant.io
QDRANT_API_KEY=                          # From Qdrant Cloud dashboard
QDRANT_COLLECTION_ALIAS=cbse_class10_live # App ALWAYS targets this alias

# --- Database (Neon Postgres) ----------------------------------
# Use the POOLED connection string from Neon dashboard (uses PgBouncer)
DATABASE_URL=                            # postgresql://user:pass@host.neon.tech/dbname?sslmode=require

# --- Auth (Clerk) ----------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=       # From Clerk dashboard -- safe to expose to browser
CLERK_SECRET_KEY=                        # From Clerk dashboard -- NEVER expose to browser
CLERK_WEBHOOK_SECRET=                    # From Clerk webhook config -- verifies webhook signatures
# Clerk redirect URLs (configure matching paths in Clerk dashboard)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/chat
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/chat

# --- Redis (Upstash REST -- NOT ioredis socket) ----------------
UPSTASH_REDIS_REST_URL=                  # From Upstash console -- REST endpoint
UPSTASH_REDIS_REST_TOKEN=                # From Upstash console -- required for HTTP auth

# --- Observability --------------------------------------------
SENTRY_DSN=
POSTHOG_KEY=                             # Optional. Or use DB events table.

# --- Encryption (AES-GCM at rest) ------------------------------
ENCRYPTION_KEY=                          # 32-byte hex key (64 characters). Generate with: openssl rand -hex 32
ENCRYPTION_KEY_VERSION=v1                # Active key identifier for database column tracking
ENCRYPTION_KEYRING=                      # JSON-encoded keyring for rotations. e.g. {"v1":"key1","v2":"key2"}

# --- Crisis & Helpline -----------------------------------------
CRISIS_HELPLINE_NAME=iCall (India)
CRISIS_HELPLINE_NUMBER=9152987821
CRISIS_REVIEW_DATE=2026-12-31

# --- Cron secret (Vercel Cron security) ------------------------
CRON_SECRET=                             # Generate a random secure string (shared between Vercel and Cron API)

# --- Application ----------------------------------------------
CURRICULUM_VERSION=2024-ncert            # Bump this on every re-ingestion to invalidate caches
CONTENT_STORAGE_MODE=chunk_only         # chunk_only (production) | full_text (dev only)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
MONITOR_SECRET=                          # Secret token to protect readiness endpoint (/api/health/readiness)
